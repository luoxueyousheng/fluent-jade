{
  "name": "@fluent-jade/ui",
  "version": "0.1.0",
  "description": "Fluent UI × JadeView 组件库 — WinUI 3 视觉/动效 + antd API(桌面 WebView 优先)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luoxueyousheng/fluent-jade.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./src/styles/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/copy-file.mjs src/styles/theme.css dist/styles/theme.css"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./theme.css": "./dist/styles/theme.css"
    }
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@fluent-jade/icon": "*",
    "motion": "^12.42.2"
  }
}
